<%- include('../partials/header'); %>
<%- include('../partials/navbar'); %>

<div class="container main-content">
  <h1>Vehículos</h1>
  
  <table class="table">
    <thead>
      <tr>
        <th>Placa</th>
        <th>Modelo</th>
        <th>Año</th>
        <th>Clase</th>
        <th>Propietario</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (vehiculos.length > 0) { %>
        <% vehiculos.forEach(function(vehiculo) { %>
          <tr>
            <td><%= vehiculo.placa %></td>
            <td><%= vehiculo.modelo %></td>
            <td><%= vehiculo.año %></td>
            <td><%= vehiculo.clase %></td>
            <td><%= vehiculo.ci_propietario %></td>
            <td>
              <a href="/vehiculos/<%= vehiculo.placa %>" class="btn btn-sm">Ver</a>
              <a href="/vehiculos/<%= vehiculo.placa %>/editar" class="btn btn-sm">Editar</a>
            </td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr>
          <td colspan="6" class="text-center">No hay vehículos registrados</td>
        </tr>
      <% } %>
    </tbody>
  </table>
  
  <div class="actions">
    <a href="/vehiculos/nuevo" class="btn btn-primary">Registrar Vehículo</a>
    <a href="/" class="btn btn-secondary">Dashboard</a>
  </div>
</div>

<%- include('../partials/footer'); %>