<%- include('../partials/header'); %>
<%- include('../partials/navbar'); %>

<div class="container main-content">
  <h1>Propietarios</h1>
  
  <table class="table">
    <thead>
      <tr>
        <th>CI</th>
        <th>Nombres</th>
        <th>Apellidos</th>
        <th>Email</th>
        <th>Teléfono</th>
        <th>Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% if (propietarios.length > 0) { %>
        <% propietarios.forEach(function(prop) { %>
          <tr>
            <td><%= prop.ci %></td>
            <td><%= prop.nombres %></td>
            <td><%= prop.apellidos %></td>
            <td><%= prop.email %></td>
            <td><%= prop.telefono_movil %></td>
            <td>
              <a href="/propietarios/<%= prop.ci %>" class="btn btn-sm">Ver</a>
              <a href="/propietarios/<%= prop.ci %>/editar" class="btn btn-sm">Editar</a>
            </td>
          </tr>
        <% }); %>
      <% } else { %>
        <tr>
          <td colspan="6" class="text-center">No hay propietarios registrados</td>
        </tr>
      <% } %>
    </tbody>
  </table>
  
  <div class="actions">
    <a href="/propietarios/nuevo" class="btn btn-primary">Registrar Propietario</a>
    <a href="/" class="btn btn-secondary">Dashboard</a>
  </div>
</div>

<%- include('../partials/footer'); %>