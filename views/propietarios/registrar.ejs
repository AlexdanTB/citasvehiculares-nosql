<%- include('../partials/header'); %>
<%- include('../partials/navbar'); %>

<div class="container main-content">
  <h1><%= propietario ? 'Editar' : 'Registrar' %> Propietario</h1>
  
  <form method="POST" action="<%= propietario ? '/propietarios/' + propietario.ci + '?_method=PUT' : '/propietarios' %>" class="form">
    <div class="form-group">
      <label for="ci">Cédula de Identidad:</label>
      <input type="text" id="ci" name="ci" value="<%= propietario ? propietario.ci : '' %>" <%= propietario ? 'readonly' : '' %> required>
    </div>
    
    <div class="form-group">
      <label for="nombres">Nombres:</label>
      <input type="text" id="nombres" name="nombres" value="<%= propietario ? propietario.nombres : '' %>" required>
    </div>
    
    <div class="form-group">
      <label for="apellidos">Apellidos:</label>
      <input type="text" id="apellidos" name="apellidos" value="<%= propietario ? propietario.apellidos : '' %>" required>
    </div>
    
    <div class="form-group">
      <label for="email">Email:</label>
      <input type="email" id="email" name="email" value="<%= propietario ? propietario.email : '' %>" required>
    </div>
    
    <div class="form-group">
      <label for="telefono_movil">Teléfono Móvil:</label>
      <input type="text" id="telefono_movil" name="telefono_movil" value="<%= propietario ? propietario.telefono_movil : '' %>" required>
    </div>
    
    <div class="form-group">
      <label for="telefono_convencional">Teléfono Convencional:</label>
      <input type="text" id="telefono_convencional" name="telefono_convencional" value="<%= propietario && propietario.telefono_convencional ? propietario.telefono_convencional : '' %>">
    </div>
    
    <% if (propietario) { %>
    <div class="form-group">
      <label>
        <input type="checkbox" id="activo" name="activo" <%= propietario.activo ? 'checked' : '' %>> Activo
      </label>
    </div>
    <% } %>
    
    <div class="actions">
      <button type="submit" class="btn btn-primary"><%= propietario ? 'Actualizar' : 'Registrar' %></button>
      <a href="/propietarios" class="btn btn-secondary">Cancelar</a>
    </div>
  </form>
</div>

<%- include('../partials/footer'); %>